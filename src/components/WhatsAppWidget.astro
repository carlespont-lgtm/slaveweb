---
import { useTranslations, type Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const phone = '34722175283';
const msg = encodeURIComponent(t('wa.prefill'));
const href = `https://wa.me/${phone}?text=${msg}`;
---
<a
  href={href}
  target="_blank"
  rel="noopener"
  aria-label="WhatsApp"
  class="group fixed bottom-5 right-5 z-[90] flex items-center gap-3"
>
  <span class="hidden max-w-0 overflow-hidden whitespace-nowrap rounded-full bg-white py-2 text-sm font-semibold text-ink-900 opacity-0 shadow-lg transition-all duration-300 group-hover:max-w-xs group-hover:px-4 group-hover:opacity-100 sm:block">
    {t('wa.title')}
  </span>
  <span class="grid h-14 w-14 place-items-center rounded-full bg-[#25D366] text-white shadow-xl transition hover:scale-105">
    <svg viewBox="0 0 32 32" class="h-8 w-8" fill="currentColor" aria-hidden="true">
      <path d="M16.04 4C9.96 4 5 8.96 5 15.04c0 1.94.51 3.84 1.48 5.52L5 28l7.6-1.45a11 11 0 0 0 3.44.56h.01c6.08 0 11.04-4.96 11.04-11.04C27.09 8.96 22.12 4 16.04 4Zm0 20.18h-.01a9.1 9.1 0 0 1-3.16-.58l-.55-.2-4.51.86.86-4.39-.21-.57a9.06 9.06 0 1 1 7.58 4.88Zm5.2-6.79c-.28-.14-1.68-.83-1.94-.92-.26-.1-.45-.14-.64.14-.19.28-.74.92-.9 1.11-.17.19-.33.21-.61.07-.28-.14-1.2-.44-2.28-1.41-.84-.75-1.41-1.68-1.58-1.96-.16-.28-.02-.43.12-.57.13-.13.28-.33.42-.5.14-.17.19-.28.28-.47.1-.19.05-.35-.02-.49-.07-.14-.64-1.54-.88-2.11-.23-.55-.46-.48-.64-.49l-.54-.01c-.19 0-.5.07-.76.35-.26.28-1 .98-1 2.38s1.02 2.76 1.16 2.95c.14.19 2.01 3.07 4.88 4.3.68.29 1.21.47 1.63.6.68.22 1.31.19 1.8.12.55-.08 1.68-.69 1.92-1.35.24-.66.24-1.23.17-1.35-.07-.12-.26-.19-.54-.33Z" />
    </svg>
  </span>
</a>
