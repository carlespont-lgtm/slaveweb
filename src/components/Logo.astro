---
interface Props {
  size?: 'md' | 'lg';
  class?: string;
}
const { size = 'md', class: className = '' } = Astro.props;
const mark = size === 'lg' ? 'h-10 w-10' : 'h-9 w-9';
const wm = size === 'lg' ? 'h-6 sm:h-7' : 'h-6';
const uid = `slv-${size}`;
---
<span class={`flex items-center gap-2.5 ${className}`} aria-label="Slave Computer">
  <span class={`relative ${mark} shrink-0`}>
    <svg viewBox="0 0 48 48" class="h-full w-full drop-shadow-sm" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <linearGradient id={`${uid}-g`} x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#34d39e" />
          <stop offset="0.55" stop-color="#16bd95" />
          <stop offset="1" stop-color="#0c7d68" />
        </linearGradient>
      </defs>
      <rect width="48" height="48" rx="13" fill={`url(#${uid}-g)`} />
      <path d="M0 13 A13 13 0 0 1 13 0 H35 A13 13 0 0 1 48 13 V20 H0 Z" fill="#ffffff" opacity="0.12" />
      <!-- cadena / eslabó (joc amb "slave") — un baula daurada (groc Slave) -->
      <g transform="translate(10,10) scale(1.16)" fill="none" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" stroke="#fde047" />
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" stroke="#ffffff" />
      </g>
    </svg>
  </span>
  <img src="/brand/slave-logo.png" alt="Slave Computer" width="760" height="153" class={`${wm} w-auto`} />
</span>
