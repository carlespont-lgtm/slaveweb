---
import { useTranslations, type Locale } from '../i18n/utils';
import Icon from './Icon.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const brands = [
  { name: 'SIAM Cloud', mark: '/brand/siamcloud-mark.svg', url: 'https://siamcloud.es', desc: 'brand.siam' },
  { name: 'GestioERP', mark: '/brand/gestioerp-mark.svg', url: 'https://gestioerp.com', desc: 'brand.ge' },
  { name: 'Fitoware', mark: '/brand/fitoware-mark.svg', url: 'https://fitoware.com', desc: 'brand.fito' },
];
---
<div class="mt-12 grid gap-4 sm:grid-cols-3">
  {
    brands.map((b) => (
      <a
        href={b.url}
        target="_blank"
        rel="noopener"
        class="group flex items-center gap-4 rounded-2xl border border-white/15 bg-white/5 p-5 backdrop-blur transition hover:bg-white/10"
      >
        <img src={b.mark} alt={b.name} width="48" height="48" class="h-12 w-12 shrink-0 rounded-xl shadow" />
        <div class="min-w-0">
          <p class="font-bold text-white">{b.name}</p>
          <p class="truncate text-sm text-brand-50/70">{t(b.desc)}</p>
        </div>
        <Icon name="external" class="ml-auto h-4 w-4 shrink-0 text-white/40 transition group-hover:text-white/80" />
      </a>
    ))
  }
</div>
