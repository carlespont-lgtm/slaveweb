---
import Icon from './Icon.astro';

interface Props {
  icon: string;
  class?: string;
}
const { icon, class: className = '' } = Astro.props;
const bars = [42, 70, 52, 90, 62, 78];
---
<div class={`overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl ${className}`}>
  <!-- barra de títol -->
  <div class="flex items-center gap-2 border-b border-slate-100 bg-slate-50 px-4 py-3">
    <span class="h-3 w-3 rounded-full" style="background:#f87171"></span>
    <span class="h-3 w-3 rounded-full" style="background:#fbbf24"></span>
    <span class="h-3 w-3 rounded-full" style="background:#34d399"></span>
    <span class="ml-3 h-4 w-40 max-w-[45%] rounded bg-slate-200"></span>
  </div>
  <div class="flex">
    <!-- barra lateral -->
    <div class="hidden w-1/4 shrink-0 space-y-2.5 border-r border-slate-100 bg-slate-50/70 p-4 sm:block">
      <div class="h-2.5 w-full rounded bg-slate-200"></div>
      <div class="h-2.5 w-4/5 rounded bg-slate-200/70"></div>
      <div class="h-2.5 w-3/5 rounded bg-brand-300"></div>
      <div class="h-2.5 w-4/5 rounded bg-slate-200/70"></div>
      <div class="h-2.5 w-2/3 rounded bg-slate-200/70"></div>
    </div>
    <!-- contingut -->
    <div class="flex-1 p-6">
      <div class="flex items-center gap-3">
        <span class="grid h-14 w-14 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-ink-800 text-white shadow-sm">
          <Icon name={icon} class="h-7 w-7" />
        </span>
        <div class="space-y-2">
          <div class="h-3 w-32 rounded bg-slate-300"></div>
          <div class="h-2.5 w-24 rounded bg-slate-200"></div>
        </div>
      </div>

      <div class="mt-6 grid grid-cols-3 gap-3">
        {
          [0, 1, 2].map(() => (
            <div class="rounded-xl border border-slate-100 bg-slate-50/70 p-3">
              <div class="h-2 w-10 rounded bg-slate-200"></div>
              <div class="mt-2 h-4 w-12 rounded bg-brand-300"></div>
            </div>
          ))
        }
      </div>

      <div class="mt-5 flex h-16 items-end gap-2">
        {bars.map((h) => <div class="flex-1 rounded-t bg-gradient-to-t from-brand-500 to-brand-300" style={`height:${h}%`} />)}
      </div>

      <div class="mt-5 space-y-2.5">
        <div class="h-2.5 w-full rounded bg-slate-100"></div>
        <div class="h-2.5 w-11/12 rounded bg-slate-100"></div>
        <div class="h-2.5 w-4/5 rounded bg-slate-100"></div>
      </div>
    </div>
  </div>
</div>
