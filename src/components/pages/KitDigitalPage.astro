---
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';
import Icon from '../Icon.astro';
import { kdHero, kdItems, t3k } from '../../data/kitdigital';
import { accentColors } from '../../data/services';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---
<!-- HERO -->
<section class="relative overflow-hidden bg-gradient-to-br from-ink-950 via-ink-900 to-brand-800">
  <div class="slv-dots absolute inset-0 opacity-60"></div>
  <div class="pointer-events-none absolute -right-32 -top-24 h-96 w-96 rounded-full bg-gold-400/20 blur-3xl"></div>
  <div class="relative mx-auto max-w-4xl px-4 py-20 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3.5 py-1.5 text-sm font-semibold text-white backdrop-blur">
      <span class="grid h-5 w-5 place-items-center rounded bg-gold-400 text-[10px] font-black text-ink-900">KD</span>
      {t3k(kdHero.eyebrow, locale)}
    </span>
    <h1 class="mx-auto mt-6 max-w-3xl text-3xl font-extrabold tracking-tight text-white sm:text-5xl">{t3k(kdHero.title, locale)}</h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-brand-50/85">{t3k(kdHero.subtitle, locale)}</p>
    <div class="mt-8">
      <a href={localizedPath('contact', locale)} class="btn-shine inline-flex items-center gap-2 rounded-lg bg-brand-500 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-900/30 transition hover:bg-brand-400">
        {t('cta.button')} <Icon name="arrow" class="h-5 w-5" />
      </a>
    </div>
  </div>
</section>

<!-- SOLUCIONS DE DIGITALITZACIÓ -->
<section class="bg-white py-20">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t3k(kdHero.eyebrow, locale)}</h2>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        kdItems.map((item) => {
          const a = accentColors[item.accent] ?? accentColors.emerald;
          return (
            <a href={item.href} class="reveal group flex flex-col rounded-2xl border border-slate-100 bg-slate-50/60 p-7 transition duration-300 hover:-translate-y-1.5 hover:border-brand-300 hover:bg-white hover:shadow-md">
              <span class="grid h-12 w-12 place-items-center rounded-xl text-white shadow-sm" style={`background:linear-gradient(135deg, ${a.from}, ${a.to})`}>
                <Icon name={item.icon} class="h-6 w-6" />
              </span>
              <h3 class="mt-5 text-lg font-bold text-ink-900">{t3k(item.title, locale)}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{t3k(item.desc, locale)}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold transition group-hover:gap-2.5" style={`color:${a.text}`}>
                {t('svc.more')} <Icon name="arrow" class="h-4 w-4" />
              </span>
            </a>
          );
        })
      }
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-3xl px-4 text-center">
    <h2 class="text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t('cta.title')}</h2>
    <p class="mt-4 text-lg text-slate-600">{t('cta.subtitle')}</p>
    <a href={localizedPath('contact', locale)} class="mt-8 inline-flex items-center gap-2 rounded-lg bg-brand-500 px-7 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-brand-600">
      {t('cta.button')} <Icon name="arrow" class="h-5 w-5" />
    </a>
  </div>
</section>
