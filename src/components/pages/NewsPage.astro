---
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';
import Icon from '../Icon.astro';
import { latest, t3n } from '../../data/news';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const newsPath = (slug: string) => `${localizedPath('news', locale)}/${slug}`;
const fmtDate = (iso: string) => {
  const [y, m, d] = iso.split('-');
  return `${d}/${m}/${y}`;
};
---
<section class="border-b border-slate-100 bg-gradient-to-b from-slate-50 to-white">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:py-20">
    <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('news.eyebrow')}</p>
    <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-ink-900 sm:text-5xl">{t('news.title')}</h1>
    <p class="mt-5 max-w-2xl text-lg text-slate-600">{t('news.subtitle')}</p>
  </div>
</section>

<section class="bg-white py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        latest.map((p) => (
          <a href={newsPath(p.slug)} class="reveal group flex flex-col rounded-2xl border border-slate-100 bg-slate-50/60 p-7 transition duration-300 hover:-translate-y-1.5 hover:border-brand-300 hover:bg-white hover:shadow-md">
            <div class="flex items-center gap-2 text-xs font-semibold">
              <span class="rounded-full bg-brand-100 px-2.5 py-1 text-brand-700">{t3n(p.tag, locale)}</span>
              <time class="text-slate-400">{fmtDate(p.date)}</time>
            </div>
            <h3 class="mt-4 text-lg font-bold leading-snug text-ink-900">{t3n(p.title, locale)}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{t3n(p.excerpt, locale)}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 transition group-hover:gap-2.5">
              {t('news.readmore')} <Icon name="arrow" class="h-4 w-4" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
