---
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';
import Icon from '../Icon.astro';
import ServiceMockup from '../ServiceMockup.astro';
import { categories, itemsByCat, t3, type Item } from '../../data/services';

interface Props {
  locale: Locale;
  item: Item;
}
const { locale, item } = Astro.props;
const t = useTranslations(locale);
const cat = categories[item.cat];
const related = itemsByCat(item.cat).filter((i) => i.slug !== item.slug).slice(0, 3);
const detailPath = (slug: string) => `${localizedPath('service', locale)}/${slug}`;
const overviewPath = localizedPath(cat.segment, locale);
---
<!-- HERO -->
<section class="relative overflow-hidden bg-gradient-to-br from-ink-950 via-ink-900 to-brand-800">
  <div class="slv-dots absolute inset-0 opacity-60"></div>
  <div class="pointer-events-none absolute -right-32 -top-24 h-96 w-96 rounded-full bg-sky-ai-500/20 blur-3xl"></div>
  <div class="relative mx-auto max-w-6xl px-4 py-16 sm:py-20">
    <a href={overviewPath} class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-300 transition hover:text-brand-200">
      ← {t3(cat.hero.eyebrow, locale)}
    </a>
    <div class="mt-6 grid items-center gap-12 lg:grid-cols-2">
      <div class="max-w-xl">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3 py-1.5 text-sm font-semibold text-white backdrop-blur">
          <Icon name={item.icon} class="h-4 w-4 text-brand-300" />
          {t3(cat.hero.eyebrow, locale)}
        </span>
        <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">{t3(item.title, locale)}</h1>
        <p class="mt-4 text-lg font-medium text-brand-100">{t3(item.tagline, locale)}</p>
        <p class="mt-4 leading-relaxed text-brand-50/85">{t3(item.intro, locale)}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={localizedPath('contact', locale)} class="btn-shine inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-900/30 transition hover:bg-brand-400">
            {t('cta.button')} <Icon name="arrow" class="h-4 w-4" />
          </a>
          <a href={localizedPath('support', locale)} class="inline-flex items-center gap-2 rounded-lg border border-white/25 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/15">
            <Icon name="headset" class="h-4 w-4" /> {t('nav.support')}
          </a>
        </div>
      </div>
      <div class="reveal is-visible">
        <ServiceMockup icon={item.icon} class="mx-auto max-w-md lg:max-w-none" />
      </div>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="bg-white py-20">
  <div class="mx-auto max-w-5xl px-4">
    <h2 class="text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t3(item.title, locale)}</h2>
    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {
        item.features.map((f) => (
          <div class="reveal flex items-start gap-3 rounded-2xl border border-slate-100 bg-slate-50/60 p-6">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-brand-100 text-brand-700">
              <Icon name="check" class="h-5 w-5" />
            </span>
            <p class="text-sm font-medium text-slate-700">{t3(f, locale)}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- RELACIONATS -->
{
  related.length > 0 && (
    <section class="bg-slate-50 py-20">
      <div class="mx-auto max-w-6xl px-4">
        <div class="flex items-end justify-between gap-4">
          <h2 class="text-2xl font-extrabold tracking-tight text-ink-900 sm:text-3xl">{t3(cat.cardsTitle, locale)}</h2>
          <a href={overviewPath} class="hidden shrink-0 items-center gap-1.5 text-sm font-semibold text-brand-700 transition hover:gap-2.5 sm:inline-flex">
            {t3(cat.hero.eyebrow, locale)} <Icon name="arrow" class="h-4 w-4" />
          </a>
        </div>
        <div class="mt-8 grid gap-5 sm:grid-cols-3">
          {related.map((r) => (
            <a href={detailPath(r.slug)} class="group flex flex-col rounded-2xl border border-slate-100 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-1.5 hover:border-brand-300 hover:shadow-md">
              <span class="grid h-11 w-11 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-ink-800 text-white shadow-sm">
                <Icon name={r.icon} class="h-6 w-6" />
              </span>
              <h3 class="mt-4 text-base font-bold text-ink-900">{t3(r.title, locale)}</h3>
              <p class="mt-1.5 flex-1 text-sm leading-relaxed text-slate-600">{t3(r.tagline, locale)}</p>
              <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 transition group-hover:gap-2.5">
                <Icon name="arrow" class="h-4 w-4" />
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
