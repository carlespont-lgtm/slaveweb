---
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';
import Icon from '../Icon.astro';
import Illustration from '../Illustration.astro';
import BrandFamily from '../BrandFamily.astro';
import Partners from '../Partners.astro';
import { itemsByCat, accentOf, svcIllo, t3 } from '../../data/services';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const chMock = `/mockups/control-horari${locale === 'ca' ? '-ca' : locale === 'en' ? '-en' : ''}.svg`;

const servItems = itemsByCat('serv');
const svcPath = (slug: string) =>
  slug === 'fitoware-vivers' ? localizedPath('product', locale) : `${localizedPath('service', locale)}/${slug}`;

const stats = [
  { k: 'years', count: 15, prefix: '+' },
  { k: 'projects', count: 100, prefix: '+' },
  { k: 'group', logo: '/brand/siamcloud-mark.svg' },
  { k: 'product', logo: '/brand/fitoware-mark.svg' },
];

const modules = [
  { k: 'billing', icon: 'tag' },
  { k: 'accounting', icon: 'layers' },
  { k: 'tpv', icon: 'printer' },
  { k: 'crm', icon: 'sparkles' },
  { k: 'ch', icon: 'shield' },
];

const maintenance = [
  { k: '1', icon: 'server', slug: 'contracte-manteniment' },
  { k: '2', icon: 'network', slug: 'servidors' },
  { k: '3', icon: 'phone', slug: 'telefonia-voip' },
  { k: '4', icon: 'wifi', slug: 'wifi-professional' },
];
---
<!-- HERO -->
<section class="relative overflow-hidden bg-gradient-to-br from-ink-950 via-ink-900 to-brand-800">
  <div class="slv-dots absolute inset-0 opacity-60"></div>
  <div class="pointer-events-none absolute -right-32 -top-40 h-[28rem] w-[28rem] rounded-full bg-brand-400/20 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-40 -left-32 h-[28rem] w-[28rem] rounded-full bg-sky-ai-500/20 blur-3xl"></div>

  <div class="relative mx-auto max-w-6xl px-4 py-20 sm:py-24">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div class="max-w-2xl">
        <a
          href="https://siamcloud.es"
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3.5 py-1.5 text-sm font-medium text-white backdrop-blur transition hover:border-brand-300/60 hover:bg-white/15"
        >
          <img src="/brand/siamcloud-mark.svg" alt="" width="16" height="16" class="h-4 w-4" />
          {t('hero.badge')}
          <Icon name="arrow" class="h-3.5 w-3.5 text-brand-300 transition group-hover:translate-x-0.5" />
        </a>

        <h1 class="mt-6 text-4xl font-extrabold leading-[1.08] tracking-tight text-white sm:text-5xl">
          {t('hero.title1')}<br class="hidden sm:block" /> {t('hero.title2')}
        </h1>

        <p class="mt-6 text-lg leading-relaxed text-brand-50/85">{t('hero.subtitle')}</p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href={localizedPath('services', locale)}
            class="btn-shine inline-flex items-center gap-2 rounded-lg bg-brand-500 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-900/30 transition hover:bg-brand-400"
          >
            {t('hero.cta1')}
            <Icon name="arrow" class="h-5 w-5" />
          </a>
          <a
            href={localizedPath('contact', locale)}
            class="inline-flex items-center gap-2 rounded-lg border border-white/25 bg-white/5 px-7 py-3.5 text-base font-semibold text-white backdrop-blur transition hover:bg-white/15"
          >
            {t('hero.cta2')}
          </a>
        </div>
      </div>

      <div class="reveal is-visible">
        <img src="/mockups/slave-hero.svg" alt="Infraestructura, xarxes i comunicacions" width="560" height="480" class="mx-auto w-full max-w-md drop-shadow-2xl lg:max-w-lg" />
      </div>
    </div>
  </div>
</section>

<!-- CIFRAS -->
<section class="border-b border-slate-100 bg-white">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-14 sm:grid-cols-2 lg:grid-cols-4">
    {
      stats.map((s) => (
        <div class="reveal">
          {s.logo && <img src={s.logo} alt="" width="40" height="40" class="mb-3 h-10 w-10 rounded-lg shadow-sm" />}
          <p class="text-4xl font-extrabold tracking-tight text-ink-900">
            {s.count != null ? (
              <span data-count={s.count} data-prefix={s.prefix}>{s.prefix}{s.count}</span>
            ) : (
              t(`stats.${s.k}.k`)
            )}
          </p>
          <p class="mt-1.5 text-sm text-slate-500">{t(`stats.${s.k}`)}</p>
        </div>
      ))
    }
  </div>
</section>

<!-- PARTNERS -->
<Partners locale={locale} />

<!-- SERVICIOS -->
<section class="bg-slate-50 py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="max-w-2xl">
      <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('services.eyebrow')}</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t('services.title')}</h2>
      <p class="mt-4 text-lg text-slate-600">{t('services.subtitle')}</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        servItems.map((item) => (
          <a
            href={svcPath(item.slug)}
            class="reveal group flex flex-col overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm transition duration-300 hover:-translate-y-1.5 hover:shadow-md"
          >
            <span class="block overflow-hidden border-b border-slate-100">
              <Illustration name={svcIllo(item.slug)} class="transition duration-500 group-hover:scale-105" />
            </span>
            <div class="flex flex-1 flex-col p-7 pt-6">
              <h3 class="text-lg font-bold text-ink-900">{t3(item.title, locale)}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{t3(item.tagline, locale)}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold transition group-hover:gap-2.5" style={`color:${accentOf(item.slug).text}`}>
                {t('svc.more')} <Icon name="arrow" class="h-4 w-4" />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<!-- MANTENIMENT I INFRAESTRUCTURA -->
<section class="relative overflow-hidden bg-gradient-to-br from-ink-950 via-ink-900 to-brand-800 py-24">
  <div class="slv-dots absolute inset-0 opacity-50"></div>
  <div class="pointer-events-none absolute -right-32 -top-24 h-96 w-96 rounded-full bg-sky-ai-500/20 blur-3xl"></div>
  <div class="relative mx-auto max-w-6xl px-4">
    <div class="max-w-2xl">
      <p class="text-sm font-bold uppercase tracking-widest text-sky-ai-300">{t('mnt.eyebrow')}</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">{t('mnt.title')}</h2>
      <p class="mt-4 text-lg text-brand-50/80">{t('mnt.subtitle')}</p>
    </div>
    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        maintenance.map((m) => (
          <a
            href={svcPath(m.slug)}
            class="reveal group rounded-2xl border border-white/15 bg-white/5 p-7 backdrop-blur transition duration-300 hover:-translate-y-1.5 hover:border-white/25 hover:bg-white/10"
          >
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-white/10" style={`color:${accentOf(m.slug).from}`}>
              <Icon name={m.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-5 text-lg font-bold text-white">{t(`mnt.${m.k}.t`)}</h3>
            <p class="mt-2 text-sm leading-relaxed text-brand-50/70">{t(`mnt.${m.k}.d`)}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-white transition group-hover:gap-2.5">
              {t('svc.more')} <Icon name="arrow" class="h-4 w-4" />
            </span>
          </a>
        ))
      }
    </div>
    <div class="mt-12">
      <a
        href={localizedPath('maintenance', locale)}
        class="inline-flex items-center gap-2 rounded-lg border border-white/25 bg-white/10 px-7 py-3.5 text-base font-semibold text-white backdrop-blur transition hover:bg-white/20"
      >
        {t('mnt.cta')} <Icon name="arrow" class="h-5 w-5" />
      </a>
    </div>
  </div>
</section>

<!-- FITOWARE -->
<section class="bg-white py-24">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 lg:grid-cols-2">
    <div class="reveal">
      <span class="inline-flex items-center gap-2 rounded-full bg-brand-100 px-3 py-1 text-xs font-bold uppercase tracking-widest text-brand-700">
        <Icon name="leaf" class="h-3.5 w-3.5" /> {t('product.eyebrow')}
      </span>
      <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t('product.title')}</h2>
      <p class="mt-4 text-slate-600">{t('product.desc')}</p>
      <ul class="mt-6 space-y-3 text-sm text-slate-700">
        <li class="flex items-start gap-2.5"><Icon name="check" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600" />{t('product.b1')}</li>
        <li class="flex items-start gap-2.5"><Icon name="check" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600" />{t('product.b2')}</li>
        <li class="flex items-start gap-2.5"><Icon name="check" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600" />{t('product.b3')}</li>
      </ul>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={localizedPath('product', locale)} class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-600">
          {t('nav.product')} <Icon name="arrow" class="h-4 w-4" />
        </a>
        <a href="https://fitoware.com" target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-lg border border-slate-300 px-6 py-3 text-sm font-semibold text-ink-900 transition hover:border-brand-400 hover:text-brand-700">
          {t('product.cta')} <Icon name="external" class="h-4 w-4" />
        </a>
      </div>
    </div>
    <div class="reveal overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg">
      <img src="/mockups/fitoware-pasaporte.svg" alt="Fitoware" loading="lazy" class="w-full" />
    </div>
  </div>
</section>

<!-- CONTROL HORARIO (timeTracker) -->
<section class="bg-slate-50 py-24">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 lg:grid-cols-2">
    <div class="reveal order-2 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-lg lg:order-1">
      <img src={chMock} alt={t('ch.title')} loading="lazy" class="w-full" />
    </div>
    <div class="reveal order-1 lg:order-2">
      <span class="inline-flex items-center gap-2 rounded-full bg-brand-100 px-3 py-1 text-xs font-bold uppercase tracking-widest text-brand-700">
        <Icon name="shield" class="h-3.5 w-3.5" /> {t('ch.eyebrow')}
      </span>
      <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t('ch.title')}</h2>
      <p class="mt-4 text-slate-600">{t('ch.desc')}</p>
      <ul class="mt-6 space-y-3 text-sm text-slate-700">
        <li class="flex items-start gap-2.5"><Icon name="check" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600" />{t('ch.b1')}</li>
        <li class="flex items-start gap-2.5"><Icon name="check" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600" />{t('ch.b2')}</li>
        <li class="flex items-start gap-2.5"><Icon name="check" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600" />{t('ch.b3')}</li>
        <li class="flex items-start gap-2.5"><Icon name="check" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600" />{t('ch.b4')}</li>
      </ul>
      <a href="https://gestioerp.com" target="_blank" rel="noopener" class="mt-8 inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-600">
        {t('ch.cta')} <Icon name="external" class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>

<!-- MÓDULOS GESTIOERP -->
<section class="bg-white py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="max-w-2xl">
      <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('modules.eyebrow')}</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t('modules.title')}</h2>
      <p class="mt-4 text-lg text-slate-600">{t('modules.subtitle')}</p>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {
        modules.map((m) => (
          <div class="reveal flex flex-col items-center rounded-2xl border border-slate-100 bg-slate-50/60 p-6 text-center">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-ink-800 text-white shadow-sm">
              <Icon name={m.icon} class="h-6 w-6" />
            </span>
            <p class="mt-4 text-sm font-bold text-ink-900">{t(`mod.${m.k}`)}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- PRUEBA GESTIOERP -->
<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-5xl px-4">
    <div class="overflow-hidden rounded-3xl border border-brand-100 bg-gradient-to-br from-brand-50 to-white p-8 shadow-sm sm:p-12">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
          <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('demo.eyebrow')}</p>
          <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t('demo.title')}</h2>
          <p class="mt-4 text-slate-600">{t('demo.desc')}</p>
          <a
            href="https://demo.gestioerp.com/login"
            target="_blank"
            rel="noopener"
            class="btn-shine mt-6 inline-flex items-center gap-2 rounded-lg bg-brand-500 px-7 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-brand-600"
          >
            {t('demo.cta')} <Icon name="external" class="h-5 w-5" />
          </a>
          <p class="mt-3 text-xs text-slate-400">{t('demo.note')}</p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-center gap-2.5 border-b border-slate-100 pb-4">
            <img src="/brand/gestioerp-mark.svg" alt="GestioERP" width="36" height="36" class="h-9 w-9 rounded-lg" />
            <div class="text-sm">
              <p class="font-bold text-ink-900">GestioERP</p>
              <p class="text-slate-400">demo.gestioerp.com</p>
            </div>
          </div>
          <div class="flex items-center justify-between border-b border-slate-100 py-3.5">
            <span class="text-sm text-slate-500">{t('demo.user')}</span>
            <code class="rounded-md bg-slate-100 px-2.5 py-1 text-sm font-bold text-ink-900">demo</code>
          </div>
          <div class="flex items-center justify-between py-3.5">
            <span class="text-sm text-slate-500">{t('demo.pass')}</span>
            <code class="rounded-md bg-slate-100 px-2.5 py-1 text-sm font-bold text-ink-900">demo2025</code>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- GRUPO -->
<section class="relative overflow-hidden bg-ink-950 py-20">
  <div class="slv-dots absolute inset-0 opacity-40"></div>
  <div class="relative mx-auto max-w-6xl px-4">
    <div class="flex flex-col items-start gap-6 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-sm font-bold uppercase tracking-widest text-sky-ai-300">{t('group.eyebrow')}</p>
        <h2 class="mt-3 text-2xl font-extrabold tracking-tight text-white sm:text-3xl">{t('group.title')}</h2>
        <p class="mt-4 text-brand-50/80">{t('group.desc')}</p>
      </div>
      <a href="https://siamcloud.es" target="_blank" rel="noopener" class="inline-flex shrink-0 items-center gap-2 rounded-lg border border-white/25 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/15">
        {t('group.cta')} <Icon name="external" class="h-4 w-4" />
      </a>
    </div>
    <BrandFamily locale={locale} />
  </div>
</section>

<!-- CTA -->
<section class="bg-gradient-to-br from-brand-600 to-ink-900 py-20">
  <div class="mx-auto max-w-3xl px-4 text-center">
    <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">{t('cta.title')}</h2>
    <p class="mt-4 text-lg text-brand-50/90">{t('cta.subtitle')}</p>
    <a href={localizedPath('contact', locale)} class="mt-8 inline-flex items-center gap-2 rounded-lg bg-white px-7 py-3.5 text-base font-semibold text-brand-700 shadow-lg transition hover:bg-brand-50">
      {t('cta.button')} <Icon name="arrow" class="h-5 w-5" />
    </a>
  </div>
</section>
