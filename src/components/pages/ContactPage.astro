---
import { useTranslations, type Locale } from '../../i18n/utils';
import Icon from '../Icon.astro';
import Locations from '../Locations.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---
<section class="border-b border-slate-100 bg-gradient-to-b from-slate-50 to-white">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:py-20">
    <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('nav.contact')}</p>
    <h1 class="mt-3 text-4xl font-extrabold tracking-tight text-ink-900 sm:text-5xl">{t('contact.title')}</h1>
    <p class="mt-5 max-w-2xl text-lg text-slate-600">{t('contact.subtitle')}</p>
  </div>
</section>

<section class="bg-white py-20">
  <div class="mx-auto grid max-w-6xl gap-12 px-4 lg:grid-cols-5">
    <form class="reveal lg:col-span-3" onsubmit="event.preventDefault(); this.querySelector('[data-ok]').classList.remove('hidden');">
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium text-slate-700">{t('contact.name')}</span>
          <input type="text" required class="mt-1.5 w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">{t('contact.email')}</span>
          <input type="email" required class="mt-1.5 w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" />
        </label>
      </div>
      <label class="mt-5 block">
        <span class="text-sm font-medium text-slate-700">{t('contact.company')}</span>
        <input type="text" class="mt-1.5 w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" />
      </label>
      <label class="mt-5 block">
        <span class="text-sm font-medium text-slate-700">{t('contact.topic')}</span>
        <select class="mt-1.5 w-full rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30">
          <option>{t('contact.topic.any')}</option>
          <option>{t('srv.erp.t')}</option>
          <option>{t('srv.custom.t')}</option>
          <option>{t('srv.fito.t')}</option>
        </select>
      </label>
      <label class="mt-5 block">
        <span class="text-sm font-medium text-slate-700">{t('contact.message')}</span>
        <textarea rows="5" required class="mt-1.5 w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30"></textarea>
      </label>
      <button type="submit" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-brand-500 px-7 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-brand-600">
        {t('contact.send')} <Icon name="arrow" class="h-5 w-5" />
      </button>
      <p data-ok class="mt-4 hidden rounded-lg bg-brand-50 px-4 py-3 text-sm font-medium text-brand-700">✓ {t('contact.send')} ✓</p>
      <p class="mt-4 text-xs text-slate-400">{t('contact.note')}</p>
    </form>

    <aside class="reveal lg:col-span-2">
      <div class="rounded-2xl border border-slate-100 bg-slate-50/60 p-8">
        <p class="text-sm font-semibold text-slate-700">{t('contact.or')}</p>
        <ul class="mt-4 space-y-4 text-sm">
          <li class="flex items-center gap-3">
            <span class="grid h-9 w-9 place-items-center rounded-lg bg-brand-100 text-brand-700"><Icon name="mail" class="h-4 w-4" /></span>
            <a href="mailto:info@slave.net" class="font-medium text-ink-900 transition hover:text-brand-700">info@slave.net</a>
          </li>
          <li class="flex items-center gap-3">
            <span class="grid h-9 w-9 place-items-center rounded-lg bg-brand-100 text-brand-700"><Icon name="leaf" class="h-4 w-4" /></span>
            <a href="https://fitoware.com" target="_blank" rel="noopener" class="font-medium text-ink-900 transition hover:text-brand-700">fitoware.com</a>
          </li>
        </ul>
        <hr class="my-6 border-slate-200" />
        <p class="text-xs font-bold uppercase tracking-widest text-brand-600">{t('group.eyebrow')}</p>
        <div class="mt-4 space-y-3 text-sm">
          <a href="https://siamcloud.es" target="_blank" rel="noopener" class="flex items-center justify-between rounded-lg border border-slate-200 bg-white px-4 py-3 transition hover:border-brand-300">
            <span class="font-semibold text-ink-900">SIAM Cloud</span>
            <Icon name="external" class="h-4 w-4 text-slate-400" />
          </a>
          <a href="https://gestioerp.com" target="_blank" rel="noopener" class="flex items-center justify-between rounded-lg border border-slate-200 bg-white px-4 py-3 transition hover:border-brand-300">
            <span class="font-semibold text-ink-900">GestioERP</span>
            <Icon name="external" class="h-4 w-4 text-slate-400" />
          </a>
        </div>
      </div>
    </aside>
  </div>
</section>

<Locations locale={locale} />
