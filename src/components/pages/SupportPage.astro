---
import { useTranslations, type Locale } from '../../i18n/utils';
import Icon from '../Icon.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const ANYDESK = 'https://download.anydesk.com/AnyDesk.exe';
const SUPREMO = 'https://www.nanosystems.it/public/download/Supremo.exe';

const bullets = ['support.b1', 'support.b2', 'support.b3', 'support.b4'];
---
<!-- HEADER -->
<section class="relative overflow-hidden bg-gradient-to-br from-ink-950 via-ink-900 to-brand-800">
  <div class="slv-dots absolute inset-0 opacity-60"></div>
  <div class="relative mx-auto max-w-4xl px-4 py-20 text-center">
    <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-3.5 py-1.5 text-sm font-medium text-white backdrop-blur">
      <Icon name="headset" class="h-4 w-4 text-brand-300" />
      {t('support.eyebrow')}
    </span>
    <h1 class="mx-auto mt-6 max-w-3xl text-3xl font-extrabold tracking-tight text-white sm:text-5xl">{t('support.title')}</h1>
    <p class="mx-auto mt-5 max-w-2xl text-lg text-brand-50/85">{t('support.desc')}</p>
  </div>
</section>

<!-- DESCARGAS -->
<section class="bg-white py-16">
  <div class="mx-auto max-w-3xl px-4 text-center">
    <p class="text-slate-600">{t('support.tools')}</p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={ANYDESK}
        target="_blank"
        rel="noopener"
        class="inline-flex w-full items-center justify-center gap-2.5 rounded-xl px-7 py-4 text-base font-semibold text-white shadow-sm transition hover:opacity-90 sm:w-auto"
        style="background-color:#e5342b"
      >
        <Icon name="download" class="h-5 w-5" />
        {t('support.anydesk')}
      </a>
      <a
        href={SUPREMO}
        target="_blank"
        rel="noopener"
        class="inline-flex w-full items-center justify-center gap-2.5 rounded-xl px-7 py-4 text-base font-semibold text-white shadow-sm transition hover:opacity-90 sm:w-auto"
        style="background-color:#1877d1"
      >
        <Icon name="download" class="h-5 w-5" />
        {t('support.supremo')}
      </a>
    </div>
    <div class="mt-4 flex items-center justify-center gap-6 text-xs font-medium text-slate-400">
      <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full" style="background-color:#e5342b"></span>AnyDesk</span>
      <span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full" style="background-color:#1877d1"></span>Supremo</span>
    </div>
  </div>

  <!-- CHECKLIST -->
  <div class="mx-auto mt-14 max-w-4xl px-4">
    <div class="grid gap-4 sm:grid-cols-2">
      {
        bullets.map((b) => (
          <div class="reveal flex items-center gap-3 rounded-2xl border border-slate-100 bg-slate-50/60 p-5">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-brand-100 text-brand-700">
              <Icon name="check" class="h-5 w-5" />
            </span>
            <span class="text-sm font-medium text-slate-700">{t(b)}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- FORMULARIO DE SOPORTE -->
<section class="bg-slate-50 py-16">
  <div class="mx-auto max-w-2xl px-4">
    <h2 class="text-center text-2xl font-extrabold tracking-tight text-ink-900 sm:text-3xl">{t('support.form.title')}</h2>
    <form
      class="reveal mt-8 rounded-2xl border border-slate-100 bg-white p-6 shadow-sm sm:p-8"
      onsubmit="event.preventDefault(); this.querySelector('[data-ok]').classList.remove('hidden');"
    >
      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium text-slate-700">{t('contact.name')}</span>
          <input type="text" required class="mt-1.5 w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">{t('contact.email')}</span>
          <input type="email" required class="mt-1.5 w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" />
        </label>
      </div>
      <label class="mt-5 block">
        <span class="text-sm font-medium text-slate-700">{t('contact.company')}</span>
        <input type="text" class="mt-1.5 w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30" />
      </label>
      <label class="mt-5 block">
        <span class="text-sm font-medium text-slate-700">{t('contact.message')}</span>
        <textarea rows="4" required class="mt-1.5 w-full rounded-lg border border-slate-300 px-3.5 py-2.5 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-500/30"></textarea>
      </label>
      <button type="submit" class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-brand-500 px-7 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-brand-600 sm:w-auto">
        {t('contact.send')} <Icon name="arrow" class="h-5 w-5" />
      </button>
      <p data-ok class="mt-4 hidden rounded-lg bg-brand-50 px-4 py-3 text-sm font-medium text-brand-700">✓ {t('contact.send')} ✓</p>
      <p class="mt-4 text-xs text-slate-400">{t('contact.note')}</p>
    </form>
  </div>
</section>
