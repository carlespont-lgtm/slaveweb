---
import { useTranslations, localizedPath, localePrefix, type Locale } from '../i18n/utils';
import LangSwitcher from './LangSwitcher.astro';
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { itemsByCat, accentOf, accentColors, t3, type CatKey } from '../data/services';
import { latest, t3n, visualOf } from '../data/news';
import ServiceMockup from './ServiceMockup.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const home = localePrefix(locale) || '/';
const detailPath = (slug: string) => `${localizedPath('service', locale)}/${slug}`;
const newsPath = (slug: string) => `${localizedPath('news', locale)}/${slug}`;
const fmtDate = (iso: string) => {
  const [y, m, d] = iso.split('-');
  return `${d}/${m}/${y}`;
};

const hubs: { seg: string; cat: CatKey; label: string; mockIcon: string }[] = [
  { seg: 'services', cat: 'serv', label: t('nav.services'), mockIcon: 'cloud' },
  { seg: 'maintenance', cat: 'mant', label: t('nav.maintenance'), mockIcon: 'wrench' },
  { seg: 'solutions', cat: 'sol', label: t('nav.solutions'), mockIcon: 'network' },
  { seg: 'cloud', cat: 'nuvol', label: t('nav.cloud'), mockIcon: 'phone' },
];
const catAccent: Record<CatKey, string> = { serv: 'emerald', mant: 'blue', sol: 'cyan', nuvol: 'teal' };

const navLinks = [
  { href: home, label: t('nav.home') },
  { href: localizedPath('services', locale), label: t('nav.services') },
  { href: localizedPath('maintenance', locale), label: t('nav.maintenance') },
  { href: localizedPath('solutions', locale), label: t('nav.solutions') },
  { href: localizedPath('cloud', locale), label: t('nav.cloud') },
  { href: localizedPath('news', locale), label: t('nav.news') },
  { href: localizedPath('product', locale), label: t('nav.product') },
  { href: localizedPath('contact', locale), label: t('nav.contact') },
];

const triggerCls = 'inline-flex items-center gap-1 rounded-md px-2 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50 hover:text-brand-700 group-hover:text-brand-700';
const dropdownCls = 'invisible absolute top-full z-50 translate-y-1 pt-3 opacity-0 transition duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100';
const viewAllCls = 'mt-1 flex items-center justify-between rounded-xl bg-slate-50 px-4 py-2.5 text-sm font-semibold text-brand-700 transition hover:bg-brand-50';
---
<header class="sticky top-0 z-50 border-b border-slate-100 bg-white/90 backdrop-blur">
  <nav class="mx-auto flex h-20 max-w-6xl items-center justify-between gap-3 px-4">
    <a href={home} class="shrink-0" aria-label="Slave Computers">
      <Logo size="lg" />
    </a>

    <ul class="hidden items-center gap-0 xl:flex">
      <li>
        <a href={home} class="rounded-md px-2 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50 hover:text-brand-700">{t('nav.home')}</a>
      </li>
      {
        hubs.map((h, hi) => (
          <li class="group relative">
            <a href={localizedPath(h.seg, locale)} class={triggerCls}>
              {h.label}
              <Icon name="chevron-down" class="h-3.5 w-3.5 transition duration-200 group-hover:rotate-180" />
            </a>
            <div class:list={[dropdownCls, hi >= 2 ? 'right-0' : 'left-0']}>
              <div class="w-[44rem] max-w-[calc(100vw-2rem)] rounded-2xl border border-slate-200 bg-white p-3 shadow-2xl">
                <div class="grid grid-cols-1 gap-4 2xl:grid-cols-[1fr_16rem]">
                  <div>
                    <div class="grid grid-cols-2 gap-1">
                      {itemsByCat(h.cat).map((item) => (
                        <a href={detailPath(item.slug)} class="flex items-start gap-3 rounded-xl p-3 transition hover:bg-slate-50">
                          <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg text-white shadow-sm" style={`background:linear-gradient(135deg, ${accentOf(item.slug).from}, ${accentOf(item.slug).to})`}>
                            <Icon name={item.icon} class="h-5 w-5" />
                          </span>
                          <span class="min-w-0">
                            <span class="block text-sm font-bold text-ink-900">{t3(item.title, locale)}</span>
                            <span class="mt-0.5 block truncate text-xs text-slate-500">{t3(item.tagline, locale)}</span>
                          </span>
                        </a>
                      ))}
                    </div>
                    <a href={localizedPath(h.seg, locale)} class={viewAllCls}>
                      {h.label} · {t('svc.more')} <Icon name="arrow" class="h-4 w-4" />
                    </a>
                  </div>
                  <div class="hidden flex-col justify-center rounded-xl bg-slate-50/70 p-3 2xl:flex">
                    <ServiceMockup icon={h.mockIcon} accent={accentColors[catAccent[h.cat]]} class="w-full" />
                  </div>
                </div>
              </div>
            </div>
          </li>
        ))
      }

      <!-- NOTÍCIES -->
      <li class="group relative">
        <a href={localizedPath('news', locale)} class={triggerCls}>
          {t('nav.news')}
          <Icon name="chevron-down" class="h-3.5 w-3.5 transition duration-200 group-hover:rotate-180" />
        </a>
        <div class:list={[dropdownCls, 'right-0']}>
          <div class="w-[30rem] max-w-[calc(100vw-2rem)] rounded-2xl border border-slate-200 bg-white p-3 shadow-2xl">
            <div class="space-y-0.5">
              {latest.slice(0, 5).map((p) => {
                const v = visualOf(p.slug);
                return (
                  <a href={newsPath(p.slug)} class="flex items-start gap-3 rounded-xl p-2.5 transition hover:bg-slate-50">
                    <span class="grid h-14 w-20 shrink-0 place-items-center rounded-lg text-white shadow-sm" style={`background:linear-gradient(135deg, ${v.from}, ${v.to})`}>
                      <Icon name={v.icon} class="h-6 w-6" />
                    </span>
                    <span class="min-w-0">
                      <span class="flex items-center gap-2 text-xs font-semibold">
                        <span class="rounded-full bg-brand-100 px-2 py-0.5 text-brand-700">{t3n(p.tag, locale)}</span>
                        <time class="text-slate-400">{fmtDate(p.date)}</time>
                      </span>
                      <span class="mt-1 block text-sm font-semibold leading-tight text-ink-900 line-clamp-2">{t3n(p.title, locale)}</span>
                    </span>
                  </a>
                );
              })}
            </div>
            <a href={localizedPath('news', locale)} class={viewAllCls}>
              {t('news.all')} <Icon name="arrow" class="h-4 w-4" />
            </a>
          </div>
        </div>
      </li>

      <li>
        <a href={localizedPath('product', locale)} class="rounded-md px-2 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50 hover:text-brand-700">{t('nav.product')}</a>
      </li>
    </ul>

    <div class="flex items-center gap-2">
      <button
        type="button"
        class="js-search-open grid h-10 w-10 place-items-center rounded-lg text-slate-600 transition hover:bg-slate-100 hover:text-brand-700"
        aria-label={t('search.open')}
        title={t('search.open')}
      >
        <Icon name="search" class="h-5 w-5" />
      </button>
      <LangSwitcher locale={locale} />
      <a
        href={localizedPath('support', locale)}
        class="hidden items-center gap-1.5 rounded-lg bg-brand-500 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-600 sm:inline-flex"
      >
        <Icon name="headset" class="h-4 w-4" />
        {t('nav.support')}
      </a>
      <a
        href={localizedPath('contact', locale)}
        class="hidden items-center gap-1.5 rounded-lg bg-ink-900 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-ink-800 xl:inline-flex"
      >
        {t('nav.cta')} →
      </a>

      <button
        id="menu-btn"
        type="button"
        class="grid h-10 w-10 place-items-center rounded-lg text-slate-700 transition hover:bg-slate-100 xl:hidden"
        aria-label="Menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" class="menu-open h-6 w-6" />
        <Icon name="x" class="menu-close hidden h-6 w-6" />
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-slate-100 bg-white xl:hidden">
    <ul class="mx-auto max-w-6xl space-y-1 px-4 py-3">
      <li>
        <a href={home} class="block rounded-lg px-3 py-2.5 text-base font-medium text-slate-700 transition hover:bg-slate-50 hover:text-brand-700">{t('nav.home')}</a>
      </li>

      {
        hubs.map((h) => (
          <li>
            <details class="group/acc">
              <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2.5 text-base font-medium text-slate-700 transition hover:bg-slate-50 [&::-webkit-details-marker]:hidden">
                {h.label}
                <Icon name="chevron-down" class="h-4 w-4 text-slate-400 transition duration-200 group-open/acc:rotate-180" />
              </summary>
              <div class="mb-1 mt-0.5 space-y-0.5 border-l-2 border-slate-100 pl-3">
                {itemsByCat(h.cat).map((item) => (
                  <a href={detailPath(item.slug)} class="flex items-center gap-3 rounded-lg px-3 py-2 transition hover:bg-slate-50">
                    <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg text-white shadow-sm" style={`background:linear-gradient(135deg, ${accentOf(item.slug).from}, ${accentOf(item.slug).to})`}>
                      <Icon name={item.icon} class="h-4 w-4" />
                    </span>
                    <span class="text-sm font-medium text-slate-700">{t3(item.title, locale)}</span>
                  </a>
                ))}
                <a href={localizedPath(h.seg, locale)} class="block rounded-lg px-3 py-2 text-sm font-semibold text-brand-700 transition hover:bg-brand-50">{h.label} · {t('svc.more')} →</a>
              </div>
            </details>
          </li>
        ))
      }

      <li>
        <details class="group/acc">
          <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2.5 text-base font-medium text-slate-700 transition hover:bg-slate-50 [&::-webkit-details-marker]:hidden">
            {t('nav.news')}
            <Icon name="chevron-down" class="h-4 w-4 text-slate-400 transition duration-200 group-open/acc:rotate-180" />
          </summary>
          <div class="mb-1 mt-0.5 space-y-0.5 border-l-2 border-slate-100 pl-3">
            {latest.slice(0, 5).map((p) => {
              const v = visualOf(p.slug);
              return (
                <a href={newsPath(p.slug)} class="flex items-center gap-3 rounded-lg px-3 py-2 transition hover:bg-slate-50">
                  <span class="grid h-9 w-12 shrink-0 place-items-center rounded-md text-white shadow-sm" style={`background:linear-gradient(135deg, ${v.from}, ${v.to})`}>
                    <Icon name={v.icon} class="h-4 w-4" />
                  </span>
                  <span class="min-w-0">
                    <span class="block truncate text-sm font-medium text-slate-700">{t3n(p.title, locale)}</span>
                    <span class="text-xs text-slate-400">{t3n(p.tag, locale)} · {fmtDate(p.date)}</span>
                  </span>
                </a>
              );
            })}
            <a href={localizedPath('news', locale)} class="block rounded-lg px-3 py-2 text-sm font-semibold text-brand-700 transition hover:bg-brand-50">{t('news.all')} →</a>
          </div>
        </details>
      </li>

      <li>
        <a href={localizedPath('product', locale)} class="block rounded-lg px-3 py-2.5 text-base font-medium text-slate-700 transition hover:bg-slate-50 hover:text-brand-700">{t('nav.product')}</a>
      </li>
      <li>
        <a href={localizedPath('contact', locale)} class="block rounded-lg px-3 py-2.5 text-base font-medium text-slate-700 transition hover:bg-slate-50 hover:text-brand-700">{t('nav.contact')}</a>
      </li>

      <li class="flex gap-2 pt-2">
        <a
          href={localizedPath('support', locale)}
          class="inline-flex flex-1 items-center justify-center gap-1.5 rounded-lg bg-brand-500 px-4 py-2.5 text-sm font-semibold text-white"
        >
          <Icon name="headset" class="h-4 w-4" />
          {t('nav.support')}
        </a>
        <a
          href={localizedPath('contact', locale)}
          class="inline-flex flex-1 items-center justify-center gap-1.5 rounded-lg bg-ink-900 px-4 py-2.5 text-sm font-semibold text-white"
        >
          {t('nav.cta')} →
        </a>
      </li>
    </ul>
  </div>
</header>

<!-- CERCADOR GLOBAL -->
<div
  id="site-search"
  class="fixed inset-0 z-[60] hidden"
  role="dialog"
  aria-modal="true"
  aria-label={t('search.open')}
  data-endpoint={`/search-${locale}.json`}
  data-empty={t('search.empty')}
>
  <div class="ss-backdrop absolute inset-0 bg-ink-950/50 backdrop-blur-sm"></div>
  <div class="relative mx-auto mt-[10vh] w-[92%] max-w-xl">
    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl">
      <div class="flex items-center gap-3 border-b border-slate-100 px-4">
        <Icon name="search" class="h-5 w-5 shrink-0 text-slate-400" />
        <input
          id="ss-input"
          type="search"
          autocomplete="off"
          spellcheck="false"
          placeholder={t('search.placeholder')}
          aria-label={t('search.placeholder')}
          class="w-full bg-transparent py-4 text-base text-ink-900 outline-none placeholder:text-slate-400"
        />
        <kbd class="hidden shrink-0 rounded border border-slate-200 bg-slate-50 px-1.5 py-0.5 text-xs text-slate-400 sm:block">Esc</kbd>
      </div>
      <div id="ss-results" class="max-h-[60vh] overflow-y-auto p-2"></div>
      <div id="ss-empty" class="hidden px-4 py-10 text-center text-sm text-slate-500"></div>
      <div id="ss-hint" class="flex items-center justify-center gap-2 px-4 py-10 text-center text-sm text-slate-400">
        <Icon name="search" class="h-4 w-4" />
        {t('search.hint')}
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    if (window.__ssBound) return;
    window.__ssBound = true;
    var cache = {};
    var items = [];
    var sel = -1;

    function q(id) { return document.getElementById(id); }
    function modal() { return q('site-search'); }
    function isOpen() { var m = modal(); return !!m && !m.classList.contains('hidden'); }
    function norm(s) { return (s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, ''); }
    function esc(s) { return (s || '').replace(/[&<>"]/g, function (c) { return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); }

    function load(cb) {
      var m = modal();
      var url = m ? m.getAttribute('data-endpoint') : '/search-ca.json';
      if (cache[url]) { cb(cache[url]); return; }
      fetch(url).then(function (r) { return r.json(); }).then(function (d) { cache[url] = d; cb(d); }).catch(function () { cb([]); });
    }

    function open() {
      var m = modal(); if (!m) return;
      m.classList.remove('hidden');
      document.documentElement.style.overflow = 'hidden';
      load(function () {});
      var input = q('ss-input');
      setTimeout(function () { if (input) { input.focus(); input.select(); } }, 20);
    }
    function close() {
      var m = modal(); if (!m) return;
      m.classList.add('hidden');
      document.documentElement.style.overflow = '';
      var input = q('ss-input'); if (input) input.value = '';
      render('');
    }

    function search(query, docs) {
      var toks = norm(query).split(/\s+/).filter(Boolean);
      if (!toks.length) return [];
      var out = [];
      for (var j = 0; j < docs.length; j++) {
        var doc = docs[j];
        var t = norm(doc.t), d = norm(doc.d), k = norm(doc.k), b = doc.b ? norm(doc.b) : '';
        var hay = t + ' ' + d + ' ' + k + ' ' + b;
        var ok = true, score = 0;
        for (var i = 0; i < toks.length; i++) {
          var tk = toks[i];
          if (hay.indexOf(tk) === -1) { ok = false; break; }
          if (t.indexOf(tk) === 0) score += 5;
          else if (t.indexOf(tk) !== -1) score += 3;
          else if (d.indexOf(tk) !== -1 || k.indexOf(tk) !== -1) score += 2;
          else score += 1;
        }
        if (ok) out.push({ doc: doc, score: score });
      }
      out.sort(function (a, b) { return b.score - a.score; });
      return out.slice(0, 8).map(function (x) { return x.doc; });
    }

    function highlight() {
      var nodes = document.querySelectorAll('#ss-results .ss-item');
      for (var i = 0; i < nodes.length; i++) nodes[i].classList.toggle('bg-brand-50', i === sel);
      var cur = nodes[sel]; if (cur && cur.scrollIntoView) cur.scrollIntoView({ block: 'nearest' });
    }

    function render(query) {
      var results = q('ss-results'), empty = q('ss-empty'), hint = q('ss-hint');
      if (!results) return;
      if (!query) {
        results.innerHTML = ''; items = []; sel = -1;
        if (empty) empty.classList.add('hidden');
        if (hint) hint.classList.remove('hidden');
        return;
      }
      if (hint) hint.classList.add('hidden');
      load(function (docs) {
        var found = search(query, docs);
        items = found; sel = found.length ? 0 : -1;
        if (!found.length) {
          results.innerHTML = '';
          if (empty) { empty.classList.remove('hidden'); empty.textContent = (modal().getAttribute('data-empty') || '') + ' “' + query + '”'; }
          return;
        }
        if (empty) empty.classList.add('hidden');
        results.innerHTML = found.map(function (doc, i) {
          return '<a href="' + esc(doc.u) + '" class="ss-item flex items-start gap-3 rounded-xl p-3 transition ' + (i === 0 ? 'bg-brand-50' : '') + '">'
            + '<span class="mt-0.5 shrink-0 rounded-md bg-brand-100 px-2 py-0.5 text-[11px] font-semibold text-brand-700">' + esc(doc.k) + '</span>'
            + '<span class="min-w-0"><span class="block text-sm font-semibold text-ink-900">' + esc(doc.t) + '</span>'
            + '<span class="block truncate text-xs text-slate-500">' + esc(doc.d) + '</span></span></a>';
        }).join('');
      });
    }

    document.addEventListener('click', function (e) {
      var opener = e.target.closest && e.target.closest('.js-search-open');
      if (opener) { e.preventDefault(); open(); return; }
      if (isOpen() && e.target.classList && e.target.classList.contains('ss-backdrop')) close();
    });

    document.addEventListener('input', function (e) {
      if (e.target && e.target.id === 'ss-input') render(e.target.value.trim());
    });

    document.addEventListener('keydown', function (e) {
      var k = e.key;
      if ((e.metaKey || e.ctrlKey) && (k === 'k' || k === 'K')) { e.preventDefault(); if (isOpen()) close(); else open(); return; }
      if (!isOpen()) return;
      if (k === 'Escape') { e.preventDefault(); close(); }
      else if (k === 'ArrowDown') { e.preventDefault(); if (items.length) { sel = (sel + 1) % items.length; highlight(); } }
      else if (k === 'ArrowUp') { e.preventDefault(); if (items.length) { sel = (sel - 1 + items.length) % items.length; highlight(); } }
      else if (k === 'Enter') { var nodes = document.querySelectorAll('#ss-results .ss-item'); var cur = nodes[sel]; if (cur) { e.preventDefault(); window.location.href = cur.getAttribute('href'); } }
    });

    // En navegar amb view transitions, netejar l'estat del cercador.
    document.addEventListener('astro:after-swap', function () { document.documentElement.style.overflow = ''; });
  })();
</script>

<script is:inline>
  (function () {
    function initMenu() {
      var btn = document.getElementById('menu-btn');
      var menu = document.getElementById('mobile-menu');
      if (!btn || !menu || btn.dataset.bound) return;
      btn.dataset.bound = '1';
      function setOpen(open) {
        menu.classList.toggle('hidden', !open);
        btn.setAttribute('aria-expanded', String(open));
        var o = btn.querySelector('.menu-open');
        var c = btn.querySelector('.menu-close');
        if (o) o.classList.toggle('hidden', open);
        if (c) c.classList.toggle('hidden', !open);
      }
      btn.addEventListener('click', function () {
        setOpen(menu.classList.contains('hidden'));
      });
      menu.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () { setOpen(false); });
      });
      window.addEventListener('resize', function () {
        if (window.innerWidth >= 1280) setOpen(false);
      });
    }
    document.addEventListener('astro:page-load', initMenu);
    if (document.readyState !== 'loading') initMenu();
    else document.addEventListener('DOMContentLoaded', initMenu);
  })();
</script>
