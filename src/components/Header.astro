---
import { useTranslations, localizedPath, localePrefix, type Locale } from '../i18n/utils';
import LangSwitcher from './LangSwitcher.astro';
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { itemsByCat, accentOf, accentColors, t3, type CatKey } from '../data/services';
import { kdItems, t3k } from '../data/kitdigital';
import { latest, t3n } from '../data/news';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const home = localePrefix(locale) || '/';
const detailPath = (slug: string) => `${localizedPath('service', locale)}/${slug}`;
const newsPath = (slug: string) => `${localizedPath('news', locale)}/${slug}`;
const fmtDate = (iso: string) => {
  const [y, m, d] = iso.split('-');
  return `${d}/${m}/${y}`;
};

const hubs: { seg: string; cat: CatKey; label: string }[] = [
  { seg: 'services', cat: 'serv', label: t('nav.services') },
  { seg: 'maintenance', cat: 'mant', label: t('nav.maintenance') },
  { seg: 'solutions', cat: 'sol', label: t('nav.solutions') },
  { seg: 'cloud', cat: 'nuvol', label: t('nav.cloud') },
];

const navLinks = [
  { href: home, label: t('nav.home') },
  { href: localizedPath('services', locale), label: t('nav.services') },
  { href: localizedPath('maintenance', locale), label: t('nav.maintenance') },
  { href: localizedPath('solutions', locale), label: t('nav.solutions') },
  { href: localizedPath('cloud', locale), label: t('nav.cloud') },
  { href: localizedPath('kitdigital', locale), label: t('nav.kitdigital') },
  { href: localizedPath('news', locale), label: t('nav.news') },
  { href: localizedPath('product', locale), label: t('nav.product') },
  { href: localizedPath('contact', locale), label: t('nav.contact') },
];

const triggerCls = 'inline-flex items-center gap-1 rounded-md px-2 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50 hover:text-brand-700 group-hover:text-brand-700';
const dropdownCls = 'invisible absolute left-0 top-full z-50 translate-y-1 pt-3 opacity-0 transition duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100';
const viewAllCls = 'mt-1 flex items-center justify-between rounded-xl bg-slate-50 px-4 py-2.5 text-sm font-semibold text-brand-700 transition hover:bg-brand-50';
---
<header class="sticky top-0 z-50 border-b border-slate-100 bg-white/90 backdrop-blur">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-3 px-4">
    <a href={home} class="shrink-0" aria-label="Slave Computers">
      <Logo size="lg" />
    </a>

    <ul class="hidden items-center gap-0 xl:flex">
      <li>
        <a href={home} class="rounded-md px-2 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50 hover:text-brand-700">{t('nav.home')}</a>
      </li>
      {
        hubs.map((h) => (
          <li class="group relative">
            <a href={localizedPath(h.seg, locale)} class={triggerCls}>
              {h.label}
              <Icon name="chevron-down" class="h-3.5 w-3.5 transition duration-200 group-hover:rotate-180" />
            </a>
            <div class={dropdownCls}>
              <div class="w-[32rem] rounded-2xl border border-slate-200 bg-white p-3 shadow-2xl">
                <div class="grid grid-cols-2 gap-1">
                  {itemsByCat(h.cat).map((item) => (
                    <a href={detailPath(item.slug)} class="flex items-start gap-3 rounded-xl p-3 transition hover:bg-slate-50">
                      <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg text-white shadow-sm" style={`background:linear-gradient(135deg, ${accentOf(item.slug).from}, ${accentOf(item.slug).to})`}>
                        <Icon name={item.icon} class="h-5 w-5" />
                      </span>
                      <span class="min-w-0">
                        <span class="block text-sm font-bold text-ink-900">{t3(item.title, locale)}</span>
                        <span class="mt-0.5 block truncate text-xs text-slate-500">{t3(item.tagline, locale)}</span>
                      </span>
                    </a>
                  ))}
                </div>
                <a href={localizedPath(h.seg, locale)} class={viewAllCls}>
                  {h.label} · {t('svc.more')} <Icon name="arrow" class="h-4 w-4" />
                </a>
              </div>
            </div>
          </li>
        ))
      }

      <!-- KIT DIGITAL -->
      <li class="group relative">
        <a href={localizedPath('kitdigital', locale)} class={triggerCls}>
          {t('nav.kitdigital')}
          <Icon name="chevron-down" class="h-3.5 w-3.5 transition duration-200 group-hover:rotate-180" />
        </a>
        <div class={dropdownCls}>
          <div class="w-[32rem] rounded-2xl border border-slate-200 bg-white p-3 shadow-2xl">
            <div class="grid grid-cols-2 gap-1">
              {kdItems.map((item) => {
                const a = accentColors[item.accent] ?? accentColors.emerald;
                return (
                  <a href={item.href} class="flex items-start gap-3 rounded-xl p-3 transition hover:bg-slate-50">
                    <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg text-white shadow-sm" style={`background:linear-gradient(135deg, ${a.from}, ${a.to})`}>
                      <Icon name={item.icon} class="h-5 w-5" />
                    </span>
                    <span class="min-w-0">
                      <span class="block text-sm font-bold text-ink-900">{t3k(item.title, locale)}</span>
                      <span class="mt-0.5 block truncate text-xs text-slate-500">{t3k(item.desc, locale)}</span>
                    </span>
                  </a>
                );
              })}
            </div>
            <a href={localizedPath('kitdigital', locale)} class={viewAllCls}>
              {t('nav.kitdigital')} · {t('svc.more')} <Icon name="arrow" class="h-4 w-4" />
            </a>
          </div>
        </div>
      </li>

      <!-- NOTÍCIES -->
      <li class="group relative">
        <a href={localizedPath('news', locale)} class={triggerCls}>
          {t('nav.news')}
          <Icon name="chevron-down" class="h-3.5 w-3.5 transition duration-200 group-hover:rotate-180" />
        </a>
        <div class={dropdownCls}>
          <div class="w-[26rem] rounded-2xl border border-slate-200 bg-white p-3 shadow-2xl">
            <div class="space-y-0.5">
              {latest.slice(0, 5).map((p) => (
                <a href={newsPath(p.slug)} class="block rounded-xl p-3 transition hover:bg-slate-50">
                  <span class="flex items-center gap-2 text-xs font-semibold">
                    <span class="rounded-full bg-brand-100 px-2 py-0.5 text-brand-700">{t3n(p.tag, locale)}</span>
                    <time class="text-slate-400">{fmtDate(p.date)}</time>
                  </span>
                  <span class="mt-1.5 block truncate text-sm font-semibold text-ink-900">{t3n(p.title, locale)}</span>
                </a>
              ))}
            </div>
            <a href={localizedPath('news', locale)} class={viewAllCls}>
              {t('news.all')} <Icon name="arrow" class="h-4 w-4" />
            </a>
          </div>
        </div>
      </li>

      <li>
        <a href={localizedPath('product', locale)} class="rounded-md px-2 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-50 hover:text-brand-700">{t('nav.product')}</a>
      </li>
    </ul>

    <div class="flex items-center gap-2">
      <LangSwitcher locale={locale} />
      <a
        href={localizedPath('support', locale)}
        class="hidden items-center gap-1.5 rounded-lg bg-brand-500 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-600 sm:inline-flex"
      >
        <Icon name="headset" class="h-4 w-4" />
        {t('nav.support')}
      </a>
      <a
        href={localizedPath('contact', locale)}
        class="hidden items-center gap-1.5 rounded-lg bg-ink-900 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-ink-800 xl:inline-flex"
      >
        {t('nav.cta')} →
      </a>

      <button
        id="menu-btn"
        type="button"
        class="grid h-10 w-10 place-items-center rounded-lg text-slate-700 transition hover:bg-slate-100 xl:hidden"
        aria-label="Menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" class="menu-open h-6 w-6" />
        <Icon name="x" class="menu-close hidden h-6 w-6" />
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-slate-100 bg-white xl:hidden">
    <ul class="mx-auto max-w-6xl space-y-1 px-4 py-3">
      {
        navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class="block rounded-lg px-3 py-2.5 text-base font-medium text-slate-700 transition hover:bg-slate-50 hover:text-brand-700"
            >
              {l.label}
            </a>
          </li>
        ))
      }
      <li class="flex gap-2 pt-2">
        <a
          href={localizedPath('support', locale)}
          class="inline-flex flex-1 items-center justify-center gap-1.5 rounded-lg bg-brand-500 px-4 py-2.5 text-sm font-semibold text-white"
        >
          <Icon name="headset" class="h-4 w-4" />
          {t('nav.support')}
        </a>
        <a
          href={localizedPath('contact', locale)}
          class="inline-flex flex-1 items-center justify-center gap-1.5 rounded-lg bg-ink-900 px-4 py-2.5 text-sm font-semibold text-white"
        >
          {t('nav.cta')} →
        </a>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  (function () {
    function initMenu() {
      var btn = document.getElementById('menu-btn');
      var menu = document.getElementById('mobile-menu');
      if (!btn || !menu || btn.dataset.bound) return;
      btn.dataset.bound = '1';
      function setOpen(open) {
        menu.classList.toggle('hidden', !open);
        btn.setAttribute('aria-expanded', String(open));
        var o = btn.querySelector('.menu-open');
        var c = btn.querySelector('.menu-close');
        if (o) o.classList.toggle('hidden', open);
        if (c) c.classList.toggle('hidden', !open);
      }
      btn.addEventListener('click', function () {
        setOpen(menu.classList.contains('hidden'));
      });
      menu.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () { setOpen(false); });
      });
      window.addEventListener('resize', function () {
        if (window.innerWidth >= 1280) setOpen(false);
      });
    }
    document.addEventListener('astro:page-load', initMenu);
    if (document.readyState !== 'loading') initMenu();
    else document.addEventListener('DOMContentLoaded', initMenu);
  })();
</script>
