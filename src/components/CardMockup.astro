---
import Icon from './Icon.astro';
import type { Accent } from '../data/services';

interface Props {
  icon: string;
  accent: Accent;
  class?: string;
}
const { icon, accent: a, class: className = '' } = Astro.props;
---
<div
  class={`relative flex items-center justify-center overflow-hidden rounded-xl ${className}`}
  style={`background:linear-gradient(135deg, ${a.from}, ${a.to})`}
>
  <!-- lluïssors i patró de punts -->
  <div class="pointer-events-none absolute -right-8 -top-10 h-28 w-28 rounded-full bg-white/25 blur-2xl"></div>
  <div class="pointer-events-none absolute -bottom-10 -left-8 h-24 w-24 rounded-full bg-black/10 blur-2xl"></div>
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.12]"
    style="background-image:radial-gradient(#fff 1px, transparent 1px);background-size:12px 12px"
  ></div>

  <!-- finestra de vidre amb icona + esquelet d'interfície -->
  <div class="relative flex items-center gap-3 rounded-xl border border-white/30 bg-white/15 px-4 py-3 shadow-lg backdrop-blur-md transition duration-300 group-hover:scale-[1.04]">
    <span class="grid h-12 w-12 shrink-0 place-items-center rounded-lg bg-white shadow-sm" style={`color:${a.text}`}>
      <Icon name={icon} class="h-6 w-6" />
    </span>
    <div class="space-y-1.5">
      <div class="h-2.5 w-20 rounded-full bg-white/85"></div>
      <div class="h-2 w-14 rounded-full bg-white/55"></div>
    </div>
  </div>
</div>
